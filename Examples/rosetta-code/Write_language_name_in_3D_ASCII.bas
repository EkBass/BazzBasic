' ============================================
' https://rosettacode.org/wiki/Write_language_name_in_3D_ASCII
' BazzBasic: https://github.com/EkBass/BazzBasic
' ============================================

[inits]
    LET data$ = ""
    LET i$, ch$

[main]
    FOR i$ = 1 TO LEN(data$) STEP 3
        ch$ = CHR(ABS(VAL(MID(data$, i$, 3))))
        IF ch$ = CHR(13) THEN
            PRINT ""
        ELSE
            PRINT ch$;
        END IF
    NEXT
    PRINT "\n\nPress ESC to exit."
    LET a$ = WAITKEY(KEY_ESC#)
END

