{
    "comments": {
        "lineComment": "REM",
        "blockComment": ["REM", ""]
    },
    "brackets": [
        ["(", ")"]
    ],
    "autoClosingPairs": [
        { "open": "(", "close": ")" },
        { "open": "\"", "close": "\"" }
    ],
    "surroundingPairs": [
        ["(", ")"],
        ["\"", "\""]
    ],
    "folding": {
        "markers": {
            "start": "^\\s*(IF|FOR|WHILE|DEF)\\b",
            "end": "^\\s*(ENDIF|NEXT|WEND|END)\\b"
        }
    },
    "wordPattern": "[a-zA-Z_][a-zA-Z0-9_]*[$#]?"
}
